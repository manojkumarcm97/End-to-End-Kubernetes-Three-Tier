# Local terraform directories
**/.terraform/*

# .tfstate files (Contains secrets! Never commit these)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude terraform.tfvars if they contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
_override.tf
_override.tf.json

# Include lock file for version consistency (Optional but recommended)
# !.terraform.lock.hcl